# ============================================
# Sweepstakes Agent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your details.
# NEVER commit your real .env file to version control!

# --- Required: Your API Key ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Required: Your Personal Info ---
SWEEPS_FIRST_NAME=Jane
SWEEPS_LAST_NAME=Doe
SWEEPS_EMAIL=jane.doe@example.com

# --- Optional: Additional Info ---
# The agent will skip sweepstakes that require fields you leave blank.
# Only fill in what you're comfortable sharing.
SWEEPS_AGE=30
SWEEPS_CITY=Anytown
SWEEPS_STATE=CA
SWEEPS_ZIP=90210
SWEEPS_COUNTRY=US

# --- Optional: Fields the agent can use if provided ---
# If left blank, the agent will automatically skip sweepstakes
# that require these as mandatory fields.
# SWEEPS_PHONE=555-555-5555
# SWEEPS_DOB=01/15/1990
# SWEEPS_ADDRESS=123 Main Street

# --- Optional: Social Media Handles ---
# SWEEPS_INSTAGRAM=@janedoe
# SWEEPS_TWITTER=@janedoe
# SWEEPS_FACEBOOK=Jane Doe

# --- Agent Settings ---
SWEEPS_MAX_ENTRIES=10
SWEEPS_DEMO_MODE=true
SWEEPS_HEADLESS=false
SWEEPS_LOG_PATH=sweepstakes_entries.json

# --- LLM Model ---
# Choose a model based on your budget and needs:
#   claude-haiku-4-5           — $1/$5 per MTok   (fastest, cheapest — good for simple entries)
#   claude-sonnet-4-6          — $3/$15 per MTok  (balanced — recommended default)
#   claude-opus-4-6            — $5/$25 per MTok  (most capable — complex forms)
#   claude-3-5-haiku-20241022  — $0.80/$4 per MTok (legacy budget option)
#   claude-3-haiku-20240307    — $0.25/$1.25 per MTok (ultra budget)
SWEEPS_LLM_MODEL=claude-sonnet-4-6
